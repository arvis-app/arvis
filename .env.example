# ──────────────────────────────────────────
# Variables d'environnement — Arvis
# Copier ce fichier en .env.local et remplir les valeurs
# ──────────────────────────────────────────

# Stripe — Prix des abonnements (depuis Stripe Dashboard > Products)
REACT_APP_STRIPE_PRICE_MONTHLY=price_xxx
REACT_APP_STRIPE_PRICE_YEARLY=price_xxx

# Supabase — optionnel (hardcodé dans supabaseClient.js par défaut)
# REACT_APP_SUPABASE_URL=https://xxxxx.supabase.co
# REACT_APP_SUPABASE_KEY=your_anon_public_key

# Sentry — suivi des erreurs en production (https://sentry.io)
REACT_APP_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
